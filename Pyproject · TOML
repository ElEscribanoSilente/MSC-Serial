[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.backends.legacy:build"

[project]
name            = "msc-serial"
version         = "1.0.0"
description     = "Reemplazo personal de pickle — seguro, comprimible, sin ejecución arbitraria"
readme          = "README.md"
license         = { file = "LICENSE" }
requires-python = ">=3.9"

authors = [
  { name = "esraderey",       email = "" },
  { name = "escribanosilente", email = "" },
]

keywords = ["serialization", "pickle", "msc", "binary"]

classifiers = [
  "License :: OSI Approved :: MIT License",
  "Programming Language :: Python :: 3",
  "Topic :: Software Development :: Libraries",
]

# Sin dependencias obligatorias; numpy es opcional
[project.optional-dependencies]
numpy = ["numpy>=1.21"]

[tool.setuptools]
py-modules = ["msc_serial"]
